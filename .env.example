# Required in production. Spring profile: dev, test or prod.
SPRING_PROFILES_ACTIVE=prod
# Required in production. JDBC URL for PostgreSQL.
SPRING_DATASOURCE_URL=jdbc:postgresql://db-host:5432/ledance_db
# Required in production. PostgreSQL application user.
SPRING_DATASOURCE_USERNAME=<set-database-user>
# Required secret in production. Never commit the real value.
SPRING_DATASOURCE_PASSWORD=<set-database-password>
# Required in production. Keep validate; schema changes belong to Flyway.
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
# Required in production. Enables forward-only Flyway migrations.
SPRING_FLYWAY_ENABLED=true
# Optional recovery setting. Keep false unless an existing untracked schema was reviewed.
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
# Optional recovery setting. Baseline version used only when baseline-on-migrate is enabled.
SPRING_FLYWAY_BASELINE_VERSION=1

# Required secret in production, at least 32 characters. Never reuse this placeholder.
JWT_SECRET=<set-random-secret-at-least-32-characters>
# Required in production. Stable issuer checked when validating tokens.
JWT_ISSUER=le-dance
# Required in production. Access-token lifetime in hours.
JWT_ACCESS_TOKEN_HOURS=2
# Required in production. Refresh-token lifetime in hours.
JWT_REFRESH_TOKEN_HOURS=168

# Required in production. SMTP server.
SPRING_MAIL_HOST=<set-smtp-host>
# Required in production. SMTP port.
SPRING_MAIL_PORT=587
# Required in production. SMTP account.
SPRING_MAIL_USERNAME=<set-smtp-user>
# Required secret in production. Never commit the real value.
SPRING_MAIL_PASSWORD=<set-smtp-password>
# Required in production. IMAP server used for the sent copy.
SPRING_MAIL_IMAP_HOST=<set-imap-host>
# Required in production. IMAPS port.
SPRING_MAIL_IMAP_PORT=993
# Required in production. IMAP account.
SPRING_MAIL_IMAP_USERNAME=<set-imap-user>
# Required secret in production. Never commit the real value.
SPRING_MAIL_IMAP_PASSWORD=<set-imap-password>
# Optional in production. Sent-mail folder name.
SPRING_MAIL_IMAP_SENT_FOLDER=INBOX.Sent

# Required in production. IANA business time zone.
APP_TIME_ZONE=America/Argentina/Buenos_Aires
# Required in production. Writable persistent directory for receipts.
APP_RECEIPTS_PATH=/var/lib/le-dance/receipts
# Required in production. Comma-separated HTTPS origins, without paths.
APP_CORS_ALLOWED_ORIGINS=https://app.example.invalid
# Optional. Production defaults to true; disable only for controlled maintenance.
APP_SCHEDULING_ENABLED=true
# Required by the current image/PDF asset resolver.
LEDANCE_HOME=/opt/le-dance
# Optional. Backend HTTP port.
SERVER_PORT=8080
# Optional. Root log level; do not enable sensitive payload logging.
LOGGING_LEVEL_ROOT=INFO

# Required at frontend production build time. Must use HTTPS outside localhost.
VITE_API_BASE_URL=https://api.example.invalid/api
# Required at frontend production build time. IANA display time zone.
VITE_APP_TIME_ZONE=America/Argentina/Buenos_Aires

# Required by PostgreSQL Compose service. Database name.
POSTGRES_DB=ledance_db
# Required by PostgreSQL Compose service. Database user.
POSTGRES_USER=<set-database-user>
# Required secret by PostgreSQL Compose service. Never commit the real value.
POSTGRES_PASSWORD=<set-database-password>
# Optional Docker-only host port.
POSTGRES_PORT=5432
# Optional Docker-only host port.
BACKEND_PORT=8080
# Optional Docker-only host port.
FRONTEND_PORT=8081
# Optional Docker-only unique name; use a different value per parallel worktree.
COMPOSE_PROJECT_NAME=le-dance
# Optional deployment image override. Local Compose builds this name when absent.
BACKEND_IMAGE=le-dance-backend:local
# Optional deployment image override. Local Compose builds this name when absent.
FRONTEND_IMAGE=le-dance-frontend:local
